{
  "name": "bullshield-browser",
  "version": "1.0.0",
  "type": "module",
  "author": {
    "name": "Pawe\u0142 Jarczak",
    "url": "https://github.com/jarczakpawel"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jarczakpawel/bullshield-browser.git"
  },
  "bugs": {
    "url": "https://github.com/jarczakpawel/bullshield-browser/issues"
  },
  "homepage": "https://github.com/jarczakpawel/bullshield-browser",
  "scripts": {
    "fmt": "node node_modules/prettier/bin/prettier.cjs --write ./src ./*.ts && npm run lint:es -- --fix",
    "lint": "npm run lint:ts && npm run lint:es",
    "lint:ts": "node node_modules/typescript/lib/tsc.js --noEmit",
    "lint:es": "node node_modules/eslint/bin/eslint.js ./src/**/*.{ts,tsx}",
    "test": "node node_modules/vitest/dist/cli.js --run --logHeapUsage --dir ./src",
    "test:cover": "node node_modules/vitest/dist/cli.js --run --dir ./src --coverage --coverage.provider=v8 --coverage.reporter=clover --coverage.reporter=text-summary",
    "watch": "node node_modules/vite/bin/vite.js build --watch --minify=false",
    "build": "node node_modules/typescript/lib/tsc.js --noEmit && node node_modules/vite/bin/vite.js build"
  },
  "dependencies": {
    "@ungap/structured-clone": "^1.3.0",
    "ipaddr.js": "^2.3.0",
    "punycode": "^2.3.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.3",
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ungap__structured-clone": "^1.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fflate": "^0.8.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "user-agent-data-types": "^0.4.2",
    "vite": "^8.0.2",
    "vitest": "^4.1.1"
  },
  "volta": {
    "node": "24.14.0"
  },
  "engines": {
    "node": ">=24"
  },
  "description": "Chromium-first anti-fingerprinting extension with coherent browser profile protection.",
  "keywords": [
    "privacy",
    "anti-fingerprinting",
    "fingerprinting",
    "chrome-extension",
    "chromium",
    "manifest-v3"
  ]
}
